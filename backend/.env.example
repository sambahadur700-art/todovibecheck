# MongoDB Atlas connection string or local MongoDB URL
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/vibecheckDB?retryWrites=true&w=majority

# JWT secret used to sign session cookies
JWT_SECRET=your_jwt_secret_here

# Google OAuth client ID for the Google Identity button
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Set to production when deploying publicly
NODE_ENV=development
PORT=5000
